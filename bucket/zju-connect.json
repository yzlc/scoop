{
    "version": "1.1.1",
    "description": "ZJU Connect - A VPN client for ZJU EasyConnect (unofficial)",
    "homepage": "https://github.com/mythologyli/zju-connect",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mythologyli/zju-connect/releases/download/v1.1.1/zju-connect-windows-amd64.zip"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.json\")) {",
        "    New-Item -ItemType File -Path \"$dir\\config.json\" -Force | Out-Null",
        "}"
    ],
    "bin": [
        [
            "zju-connect.exe",
            "zju-connect"
        ]
    ],
    "persist": "config.json",
    "checkver": {
        "github": "https://github.com/mythologyli/zju-connect"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mythologyli/zju-connect/releases/download/v$version/zju-connect-windows-amd64.zip"
            }
        }
    }
}